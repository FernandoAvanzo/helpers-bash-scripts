{
  "name": "playwright-template",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright Test template (TypeScript) with POM + custom fixtures + CI",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
